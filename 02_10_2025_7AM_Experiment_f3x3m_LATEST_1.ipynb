        "\n",
        "\n",
        "        # Enforce SLLO <= SLTO - 1\n",
        "        if txt_sllo.value > txt_slto.value - 1.0:\n",
        "             # Adjust SLLO to be at most SLTO - 1.0\n",
        "             new_sllo = round(txt_slto.value - 1.0, 1)\n",
        "             # Ensure it doesn't exceed max abs value (5.0)\n",
