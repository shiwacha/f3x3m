      "cell_type": "code",
      "source": [
        "from datetime import datetime, timedelta, date\n",
        "\n",
        "# Nifty 50 Index Token (Yeh Zerodha ka token hai)\n",
        "NIFTY_TOKEN = 256265\n",
        "\n",
        "# Start checking from today\n",
        "current_date = datetime.now(india).date()\n",
        "open_price_915 = None\n",
